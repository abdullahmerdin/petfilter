{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["build/**"]
      }
    }
  ],
  "routes": [
    { "src": "/build/client/(.*)", "dest": "/build/client/$1" },
    { "src": "/(.*)", "dest": "api/index.js" }
  ],
  "buildCommand": "npm run setup && npm run build",
  "installCommand": "npm install",
  "outputDirectory": "build"
}
